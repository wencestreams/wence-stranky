    "@11ty/eleventy-navigation": "^1.0.5",
    "@anyblades/blades": "^0.28.0-alpha.5",
    "@anyblades/eleventy-blades": "^0.28.0-beta.4",
    "@tailwindcss/cli": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "js-yaml": "^4.1.1",
    "markdown-it": "^14.1.0",
    "markdown-it-anchor": "^9.2.0",
