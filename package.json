{
  "private": true,
  "name": "@anyblades/build-awesome-starter",
  "version": "0.9.7",
  "type": "module",
  "workspaces": [
    "do"
  ],
  "scripts": {
    "11ty": "ELTY_OPTIONS='--input=./site-1 --config=./node_modules/@anyblades/eleventy-blades/src/eleventy.config.js' npm -w do run",
